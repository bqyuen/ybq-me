{"nodes":[{"id":"001-机会成本","num":"001","name":"机会成本","cat":"认知决策","desc":"你放弃的所有选项中，价值最高的那个，才是你做任何选择的真正代价"},{"id":"002-沉没成本","num":"002","name":"沉没成本","cat":"认知决策","desc":"已经花出去、无法收回的成本，不应该影响你对未来的决策"},{"id":"003-直觉","num":"003","name":"直觉","cat":"认知决策","desc":"直觉是大脑基于隐性知识和模式识别做出的快速判断——它不是理性的对立面，而是理性的另一种形式"},{"id":"004-决策树","num":"004","name":"决策树","cat":"认知决策","desc":"用树枝状图形把每个选择及其可能结果展开，计算每个路径的期望值，让不确定性变得可见和可算"},{"id":"005-非sr思维","num":"005","name":"非sr思维","cat":"认知决策","desc":"刺激和反应之间存在一个空间，在这个空间里藏着我们选择反应的自由和力量"},{"id":"006-确认偏误","num":"006","name":"确认偏误","cat":"认知决策","desc":"人天然倾向于寻找、解释和记忆那些支持自己已有信念的信息，而忽视、贬低或遗忘相反的证据"},{"id":"007-易得性偏差","num":"007","name":"易得性偏差","cat":"认知决策","desc":"人根据\\\"脑子里最容易想到的例子\\\"来判断事情发生的频率和概率，而不依据真实统计数据"},{"id":"008-逆向思维","num":"008","name":"逆向思维","cat":"认知决策","desc":"与其问\\\"如何成功\\\"，不如问\\\"如何失败\\\"；避开失败，成功自然发生——反过来想，总是反过来想"},{"id":"009-六顶思考帽","num":"009","name":"六顶思考帽","cat":"创新突破","desc":"用六种角色切换审视同一问题——白(事实)红(直觉)黑(风险)黄(乐观)绿(创意)蓝(统筹)"},{"id":"010-101010旁观","num":"010","name":"101010旁观","cat":"认知决策","desc":"在重大决策前，问自己——10分钟后、10个月后、10年后，我会怎么看待这个选择？时间距离消解情绪噪音，让真正重要的东西浮"},{"id":"011-升维思维","num":"011","name":"升维思维","cat":"系统战略","desc":"在更高维度上重构问题，使原维度的困境不攻自破"},{"id":"012-笛卡尔思维","num":"012","name":"笛卡尔思维","cat":"系统战略","desc":"通过系统性怀疑，只接受清晰且不容置疑的真理作为知识起点"},{"id":"013-第一性原理","num":"013","name":"第一性原理","cat":"分析诊断","desc":"把问题拆到不可再分的事实，从那里重新推导——而不是在别人的答案上修修补补"},{"id":"014-奥卡姆剃刀","num":"014","name":"奥卡姆剃刀","cat":"分析诊断","desc":"如无必要，勿增实体——最简单的解释往往是正确的"},{"id":"015-马斯洛需求层次理论","num":"015","name":"马斯洛需求层次理论","cat":"管理框架","desc":"人的行为动机像一座金字塔——必须先满足底层的基本需求，更高层次的需求才会成为驱动力"},{"id":"016-反脆弱","num":"016","name":"反脆弱","cat":"系统战略","desc":"不仅能在冲击中存活，还能从冲击中变得更强"},{"id":"017-万物联系","num":"017","name":"万物联系","cat":"分析诊断","desc":"系统中每一个变化都不是孤立的——寻找隐藏的连接链路"},{"id":"018-万物系统","num":"018","name":"万物系统","cat":"系统战略","desc":"任何事物都是更大系统的组成部分，理解系统才能理解事物"},{"id":"019-大脑系统","num":"019","name":"大脑系统","cat":"创新突破","desc":"理解大脑运作原理——神经可塑性、化学物质、认知架构"},{"id":"020-卡尼曼双系统","num":"020","name":"卡尼曼双系统","cat":"创新突破","desc":"系统 1（快/自动/直觉）× 系统 2（慢/控制/分析）——理解双系统是自我管理的基础"},{"id":"021-冯诺依曼","num":"021","name":"冯诺依曼","cat":"心理自我","desc":"把任何复杂决策转化为清晰的数学期望计算——从直觉到量化，是理性决策的终极路径"},{"id":"022-三层解释","num":"022","name":"三层解释","cat":"分析诊断","desc":"同一现象在不同分析层面有不同的\\\"真正原因\\\"——同时看到事件、模式与结构"},{"id":"023-损失规避","num":"023","name":"损失规避","cat":"心理自我","desc":"人对失去的痛苦远大于对等量获得的喜悦"},{"id":"024-替身决策","num":"024","name":"替身决策","cat":"管理框架","desc":"当你不知道该不该做一件事时，问自己——\\\"如果一个我尊敬的人站在我的位置，他会怎么做？\\\""},{"id":"025-多维视角","num":"025","name":"多维视角","cat":"管理框架","desc":"任何问题都有不止一种\\\"正确的视角\\\"——发现并整合这些视角，才能在复杂世界中做出健全的决策"},{"id":"026-局部全局最优","num":"026","name":"局部全局最优","cat":"执行效率","desc":"每个部分做到最好的总和，不一定等于整体最好"},{"id":"027-不平衡性","num":"027","name":"不平衡性","cat":"执行效率","desc":"系统永远是非均衡的——利用不均衡找到突破口，而不是追求完美平衡"},{"id":"028-破界思维","num":"028","name":"破界思维","cat":"创新突破","desc":"打破问题隐含的边界和假设，在更大的空间寻找答案"},{"id":"029-非线性思维","num":"029","name":"非线性思维","cat":"创新突破","desc":"跳出 A → B 直线逻辑，接受跳跃、迂回、涌现——创新往往是非线性的"},{"id":"030-自我催化","num":"030","name":"自我催化","cat":"创新突破","desc":"系统内部的某个元素催化了更多同类元素的产生——自驱动的增长引擎"},{"id":"031-优先排序","num":"031","name":"优先排序","cat":"执行效率","desc":"排序的本质不是决定先做什么，而是敢于决定永远不做什么"},{"id":"032-黄金圈思维","num":"032","name":"黄金圈思维","cat":"沟通影响","desc":"人们不为你的产品买单，他们为你的理由买单——先讲为什么，再讲是什么"},{"id":"033-心流理论","num":"033","name":"心流理论","cat":"执行效率","desc":"当挑战与技能恰好匹配时，人会进入完全沉浸的巅峰体验状态"},{"id":"034-长线思考","num":"034","name":"长线思考","cat":"执行效率","desc":"用长期视角指导当下的每一个决策——短期爽快的往往长期有害"},{"id":"035-隐含前提","num":"035","name":"隐含前提","cat":"分析诊断","desc":"每个论断都建立在未被说出的假设之上——找出它们，才能检验论证的真伪"},{"id":"036-时光机理论","num":"036","name":"时光机理论","cat":"系统战略","desc":"利用不同市场发展阶段的时间差，将已验证的模式复制到滞后市场"},{"id":"037-升维打击","num":"037","name":"升维打击","cat":"系统战略","desc":"在竞争对手无法触及的维度上发动攻击，使其在原有维度的全部优势瞬间失效"},{"id":"038-凸透放大镜思维","num":"038","name":"凸透放大镜思维","cat":"创新突破","desc":"大问题从不突然降临，它只是被你忽略了三次的小信号——放大它，趁它还小"},{"id":"039-凹透缩小镜思维","num":"039","name":"凹透缩小镜思维","cat":"分析诊断","desc":"将问题从时间或空间上拉远，整体才能显影——很多困惑在缩小的视野中自动消失"},{"id":"040-九宫格","num":"040","name":"九宫格","cat":"分析诊断","desc":"用九个维度将问题从\\\"一个点\\\"展开为\\\"一个面\\\"——结构化全景扫描，避免盲区"},{"id":"041-反作用力","num":"041","name":"反作用力","cat":"分析诊断","desc":"每个行动都会触发系统的反向响应——在用力之前，先问\\\"这力会弹回来吗？\\\""},{"id":"042-思维投影","num":"042","name":"思维投影","cat":"分析诊断","desc":"你所看到的\\\"问题\\\"是你认知框架的投影——改变框架，问题形态随之改变"},{"id":"043-蝴蝶效应","num":"043","name":"蝴蝶效应","cat":"系统战略","desc":"在非线性系统中，微小的初始差异可能通过不断的反馈放大，最终导致截然不同的结果"},{"id":"044-成长破圈","num":"044","name":"成长破圈","cat":"学习成长","desc":"成长的本质是一次次突破舒适圈——从舒适到恐惧，从学习到成长，最终建立新的、更大的舒适圈"},{"id":"045-上帝视角","num":"045","name":"上帝视角","cat":"分析诊断","desc":"跳出自我，以全知旁观者的身份审视——你不再是局中人，你同时看见所有局中人的位置"},{"id":"046-演绎法","num":"046","name":"演绎法","cat":"分析诊断","desc":"从普遍真理出发，通过严格的逻辑推导得出特定结论——前提为真，则结论必然为真"},{"id":"047-可复制化","num":"047","name":"可复制化","cat":"执行效率","desc":"把一次性的成功变成可重复的流程——从偶然到必然"},{"id":"048-幸存者偏差","num":"048","name":"幸存者偏差","cat":"学习成长","desc":"你看见的都是\\\"活下来\\\"的——从幸存者的特征推断成功的原因，而忽略了沉默的失败者"},{"id":"049-冰山理论","num":"049","name":"冰山理论","cat":"分析诊断","desc":"任何问题的可见部分只是冰山一角——真正驱动系统行为的力量在水面之下"},{"id":"050-邓克效应","num":"050","name":"邓克效应","cat":"创新突破","desc":"能力越低越容易高估自己——不知道自己的无知是最大的无知"},{"id":"051-效率思维","num":"051","name":"效率思维","cat":"执行效率","desc":"方向错了，跑得越快离目标越远——先确认在做对的事，再谈把事做对"},{"id":"052-福格行为","num":"052","name":"福格行为","cat":"执行效率","desc":"行为 = 动机 + 能力 + 提示——三者同时具备，行为必然发生"},{"id":"053-反熵增","num":"053","name":"反熵增","cat":"系统战略","desc":"对抗自然趋向混乱的趋势，通过持续输入能量维持或提升系统秩序"},{"id":"054-混沌与秩序","num":"054","name":"混沌与秩序","cat":"系统战略","desc":"混沌不是混乱，秩序不是僵化；真实世界是混沌与秩序的边界上涌现出来的持久模式"},{"id":"055-费马帕斯卡","num":"055","name":"费马帕斯卡","cat":"认知决策","desc":"世界是由概率而非确定性构成的——用期望值而非恐惧或贪婪来做决策"},{"id":"056-费曼技巧","num":"056","name":"费曼技巧","cat":"学习成长","desc":"如果你不能用简单的语言解释清楚一件事，说明你还没真正理解它"},{"id":"057-复利效应","num":"057","name":"复利效应","cat":"成本投资","desc":"复利的全部威力都在后半程，而绝大多数人，在前半程就放弃了"},{"id":"058-二八定律","num":"058","name":"二八定律","cat":"成本投资","desc":"80% 的结果来自 20% 的原因——找到那关键的少数，然后理直气壮地放弃其余"},{"id":"059-决策损失","num":"059","name":"决策损失","cat":"认知决策","desc":"任何决策都有两种损失——\\\"做错的损失\\\"和\\\"不做的损失\\\"。最优决策是最小化两种损失之和的决策"},{"id":"060-启发式偏差","num":"060","name":"启发式偏差","cat":"认知决策","desc":"大脑为了快速决策而使用的认知捷径，在复杂环境中会导致系统性的判断错误——认识它们，是理性决策的第一步"},{"id":"061-批判性思维","num":"061","name":"批判性思维","cat":"分析诊断","desc":"不自动接受任何信息——用清晰、理性、反思性的标准检验每一个论断"},{"id":"062-金字塔原理","num":"062","name":"金字塔原理","cat":"管理框架","desc":"先给结论，再给支撑这个结论的论据——金字塔顶端是核心观点，每一层是下一层的总结"},{"id":"063-MECE原则","num":"063","name":"MECE原则","cat":"管理框架","desc":"把问题切分成\\\"不重叠、不遗漏\\\"的碎片——你能看到完整的画面，不会在同一个地方看两遍，也不会漏掉某个角落"},{"id":"064-耗散结构理论","num":"064","name":"耗散结构理论","cat":"系统战略","desc":"远离平衡态的开放系统通过耗散能量，可以自发形成高度有序的结构"},{"id":"065-冗余备份","num":"065","name":"冗余备份","cat":"学习成长","desc":"在不确定的世界中，存活下来的不是\\\"最强\\\"的系统，而是预留了安全边际和备用方案的系统"},{"id":"066-路径依赖","num":"066","name":"路径依赖","cat":"系统战略","desc":"历史的选择会自我强化，使得改变方向变得越来越困难"},{"id":"067-元认知","num":"067","name":"元认知","cat":"学习成长","desc":"元认知是\\\"关于思考的思考\\\"——理解自己的思维过程并主动管理它，是高效学习与决策的起点"},{"id":"068-排列组合","num":"068","name":"排列组合","cat":"认知决策","desc":"不要只考虑你想到的第一个组合——系统地枚举所有可能性，最优解往往藏在初始直觉之外的排列里"},{"id":"069-人类误判心理","num":"069","name":"人类误判心理","cat":"学习成长","desc":"大脑是一台被数百万年演化雕刻的\\\"认知捷径机器\\\"——理解它的25个系统性偏误，你才可能做出更好的决策"},{"id":"070-遗忘曲线","num":"070","name":"遗忘曲线","cat":"学习成长","desc":"学完一小时，一半已经忘了——记忆不拼天赋，拼的是在对的时间点复习"},{"id":"071-断裂点理论","num":"071","name":"断裂点理论","cat":"学习成长","desc":"任何系统都有其承受极限——找到并管理那些\\\"再往前一点就断裂\\\"的点，是系统工程的核心智慧"},{"id":"072-杠杆原理","num":"072","name":"杠杆原理","cat":"成本投资","desc":"高手从不拼力气，他们只找支点——支点选对了，一根手指也能撬动全局"},{"id":"073-长尾理论","num":"073","name":"长尾理论","cat":"成本投资","desc":"当连接成本足够低时，需求不旺的利基产品总销量可以超过热门产品——长尾让\\\"小众\\\"成为主流"},{"id":"074-沉默的螺旋","num":"074","name":"沉默的螺旋","cat":"系统战略","desc":"当人们感觉自己的观点属于少数派时，会倾向于保持沉默，导致少数观点被系统性地低估"},{"id":"075-飞轮效应","num":"075","name":"飞轮效应","cat":"系统战略","desc":"每个正确的努力都在降低下一个努力的难度，直到系统自我推动、加速运转"},{"id":"076-SWOT分析","num":"076","name":"SWOT分析","cat":"管理框架","desc":"把内部的长板与短板、外部的风口与风口浪尖同时看到——就可以画出下一步在哪"},{"id":"077-PDCA循环","num":"077","name":"PDCA循环","cat":"执行效率","desc":"计划、执行、检查、改进——持续转动的质量飞轮"},{"id":"078-周哈里窗","num":"078","name":"周哈里窗","cat":"沟通影响","desc":"你看不见的自己，别人看得一清二楚——主动求反馈的人，才有完整的自我"},{"id":"079-煤气灯效应","num":"079","name":"煤气灯效应","cat":"沟通影响","desc":"识别心理操纵——当有人系统性让你怀疑自己的感知和判断时"},{"id":"080-系列位置效应","num":"080","name":"系列位置效应","cat":"学习成长","desc":"在一系列信息中，开头和结尾的比中间的好记得多——因为大脑对第一个和最后一个总是多看两眼"},{"id":"081-推论阶梯","num":"081","name":"推论阶梯","cat":"认知决策","desc":"我们的大脑能从\\\"我看到的\\\"瞬间跳到\\\"我相信的\\\"，中间爬过的阶梯往往自己都没有察觉——慢下来，走一遍阶梯，才能区分"},{"id":"082-反事实思维","num":"082","name":"反事实思维","cat":"认知决策","desc":"任何\\\"已经发生\\\"的事情，都存在\\\"本可以不发生\\\"的平行版本——系统地想象反事实，不是为了遗憾，而是为了在类似情境再"},{"id":"083-长短板理论","num":"083","name":"长短板理论","cat":"心理自我","desc":"最短的木板决定你盛水的高度，最长的木板决定你盛水的上限和方向——关键看你在补短板还是拉长板"},{"id":"084-鸟笼效应","num":"084","name":"鸟笼效应","cat":"沟通影响","desc":"获得一件物品会驱动配套消费——\\\"有了鸟笼就会想买鸟\\\""},{"id":"085-峰终定律","num":"085","name":"峰终定律","cat":"沟通影响","desc":"人们对体验的记忆 = 峰值时刻 + 结束时刻——中间可以模糊，峰终必须精彩"},{"id":"086-5W1H分析法","num":"086","name":"5W1H分析法","cat":"管理框架","desc":"六个问题穷尽一个问题的所有相关维度——\\\"什么、为什么、谁、哪里、何时、怎么\\\""},{"id":"087-归因效应","num":"087","name":"归因效应","cat":"心理自我","desc":"我们如何解释\\\"为什么这件事发生了\\\"——比自己以为的更主观、更偏向自己、更不可靠"},{"id":"088-HOOK上瘾模型","num":"088","name":"HOOK上瘾模型","cat":"沟通影响","desc":"触发 → 行动 → 多变的奖励 → 投入——让人持续回来的行为设计框架"},{"id":"089-情境领导理论","num":"089","name":"情境领导理论","cat":"沟通影响","desc":"根据下属的成熟度（能力 + 意愿）动态调整领导风格——没有最佳风格，只有最佳匹配"},{"id":"090-博弈论","num":"090","name":"博弈论","cat":"成本投资","desc":"多主体互动中，你的最佳选择取决于对方的选择——策略性思维"},{"id":"091-动态思维","num":"091","name":"动态思维","cat":"系统战略","desc":"承认世界是流动的，战略是在行动中持续调整的，而非提前被完整规划的"},{"id":"092-溯因推理","num":"092","name":"溯因推理","cat":"分析诊断","desc":"从观察到的结果反推最可能的原因——不是证明，而是提出最佳的待检验假设"},{"id":"093-情绪ABC理论","num":"093","name":"情绪ABC理论","cat":"心理自我","desc":"伤害你的不是事情本身，而是你对事情的解读——改变你的解读，就改变你的情绪世界"},{"id":"094-蘑菇管理","num":"094","name":"蘑菇管理","cat":"学习成长","desc":"新人不需要被\\\"阳光普照\\\"，他们需要一段在暗处默默生长的\\\"蘑菇期\\\"——但这段时期不能太长"},{"id":"095-前景理论","num":"095","name":"前景理论","cat":"成本投资","desc":"人在\\\"获得\\\"和\\\"失去\\\"框架下的决策是非对称的——失去 100 元的痛苦是获得 100 元快乐的 2 倍"},{"id":"096-双目标清单","num":"096","name":"双目标清单","cat":"成本投资","desc":"每个目标配一个\\\"反目标\\\"——明确不做什么，比明确做什么更重要"},{"id":"097-梅特卡夫法则","num":"097","name":"梅特卡夫法则","cat":"成本投资","desc":"网络的价值与用户数量的平方成正比——节点越多，每个节点的价值越大"},{"id":"098-正确与非共识","num":"098","name":"正确与非共识","cat":"成本投资","desc":"当你是正确的且大多数人不同意时，你的机会最大——但也最孤独"},{"id":"099-波特五力分析","num":"099","name":"波特五力分析","cat":"成本投资","desc":"五力决定行业利润池——五力都弱的行业才是好行业"},{"id":"100-护城河理论","num":"100","name":"护城河理论","cat":"成本投资","desc":"企业持续超越竞争对手的能力——护城河越宽，竞争优势越持久"}],"links":[{"source":"001-机会成本","target":"002-沉没成本"},{"source":"001-机会成本","target":"023-损失规避"},{"source":"001-机会成本","target":"055-费马帕斯卡"},{"source":"001-机会成本","target":"060-启发式偏差"},{"source":"001-机会成本","target":"021-冯诺依曼"},{"source":"002-沉没成本","target":"023-损失规避"},{"source":"002-沉没成本","target":"024-替身决策"},{"source":"002-沉没成本","target":"039-凹透缩小镜思维"},{"source":"002-沉没成本","target":"010-101010旁观"},{"source":"003-直觉","target":"060-启发式偏差"},{"source":"003-直觉","target":"007-易得性偏差"},{"source":"003-直觉","target":"002-沉没成本"},{"source":"003-直觉","target":"006-确认偏误"},{"source":"003-直觉","target":"020-卡尼曼双系统"},{"source":"004-决策树","target":"055-费马帕斯卡"},{"source":"004-决策树","target":"021-冯诺依曼"},{"source":"004-决策树","target":"001-机会成本"},{"source":"004-决策树","target":"059-决策损失"},{"source":"004-决策树","target":"068-排列组合"},{"source":"005-非sr思维","target":"006-确认偏误"},{"source":"005-非sr思维","target":"093-情绪ABC理论"},{"source":"005-非sr思维","target":"003-直觉"},{"source":"005-非sr思维","target":"082-反事实思维"},{"source":"005-非sr思维","target":"060-启发式偏差"},{"source":"006-确认偏误","target":"060-启发式偏差"},{"source":"006-确认偏误","target":"074-沉默的螺旋"},{"source":"006-确认偏误","target":"007-易得性偏差"},{"source":"006-确认偏误","target":"002-沉没成本"},{"source":"006-确认偏误","target":"008-逆向思维"},{"source":"007-易得性偏差","target":"060-启发式偏差"},{"source":"007-易得性偏差","target":"082-反事实思维"},{"source":"007-易得性偏差","target":"055-费马帕斯卡"},{"source":"008-逆向思维","target":"082-反事实思维"},{"source":"008-逆向思维","target":"068-排列组合"},{"source":"008-逆向思维"